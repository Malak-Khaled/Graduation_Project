# انسخ إلى `.env` في جذر المشروع (بجانب package.json). أعد تشغيل `npm run dev` بعد التعديل.

# ─── تطوير محلي (موصى به) ───
# الفرونت: http://localhost:5173  |  الباكند: php artisan serve → http://127.0.0.1:8000
VITE_API_BASE_URL=/api

# ─── بدون proxy (معاينة / أدوات) ───
# VITE_API_BASE_URL=http://127.0.0.1:8000/api
