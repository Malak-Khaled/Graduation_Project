# انسخ إلى `.env` في نفس المجلد (جذر مشروع React + Vite).
# بعد أي تعديل أعد تشغيل `npm run dev`.

# ─── ربط الفرونت بالباكند (Laravel) ───
# يجب أن ينتهي العنوان بـ `/api` لأن axios يضيف بعده المسارات من `src/api/endpoints.js`.

# [أ] تطوير مباشر: الفرونت يتصل بالباك على المنفذ 8000 (يفترض `php artisan serve` أو ما يعادله)
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# [ب] مع الـ proxy أعلاه في vite.config.js: نفس منفذ Vite بدون مشاكل CORS
# VITE_API_BASE_URL=/api

# الإنتاج أو السيرفر (مثال EC2):
# VITE_API_BASE_URL=http://18.156.7.107/api
