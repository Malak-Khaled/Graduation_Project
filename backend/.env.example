APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# عنوان التطبيق العام (روابط البريد، التخزين، إلخ)
APP_URL=http://127.0.0.1:8000

# أصول CORS للفرونت المحلي (Vite على 5173):
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# إذا استخدمت مصادقة الكوكيز مع SPA على منفذ Vite، أضف النطاقات هنا (اختياري؛ المشروع يستخدم Bearer غالباً)
# SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173,localhost:4173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL (محلي): أنشئ القاعدة أولاً، مثلاً:
#   CREATE DATABASE lesahtak CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# ثم: php artisan migrate --force && php artisan db:seed --force
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lesahtak
DB_USERNAME=root
DB_PASSWORD=

# للتطوير بدون MySQL يمكنك استخدام SQLite بدل الأسطر أعلاه:
# DB_CONNECTION=sqlite
# DB_DATABASE="${PWD}/database/database.sqlite"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Gmail example:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your_gmail_app_password
# MAIL_ENCRYPTION=tls

# SMS OTP — Africa's Talking أو مزود JSON عام
# Africa's Talking: URL يحوي africas talking.com ⇒ يُرسل كـ form-urlencoded مع header apiKey
SMS_PROVIDER_URL=
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER=
# اسم التطبيق في Africa'sTalking (sandbox يستخدم اسم المستخدم sandbox + رابط sandbox)
AT_USERNAME=sandbox
# SMS_PROVIDER_DRIVER=auto — auto | africastalking | generic_json

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Payments gateway
# fake => local success (development/testing)
# rest => calls PAYMENT_GATEWAY_ENDPOINT with Bearer PAYMENT_GATEWAY_API_KEY
PAYMENT_GATEWAY_DRIVER=fake
PAYMENT_GATEWAY_ENDPOINT=
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_TIMEOUT=15
PAYMENT_WEBHOOK_SECRET=

# AI assistant
# database => replies from ai_knowledge_entries (edit via admin API or seed JSON; no API key)
# fake => simple echo (dev only)
# openai => call AI_ENDPOINT with Bearer AI_API_KEY
AI_DRIVER=database
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_TIMEOUT=20
AI_RETRY_ATTEMPTS=1
LLM_PROVIDER=openai
# OpenRouter (Qwen) compatibility
QWEN_API_KEY=
QWEN_MODEL=qwen/qwen-2.5-72b-instruct
QWEN_FALLBACK_MODELS=qwen/qwen-2.5-7b-instruct
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# Gemini native compatibility
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-1.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
AI_SYSTEM_PROMPT="You are a safe medical assistant. Give general guidance only and suggest seeing a doctor for emergencies."
# When no keyword in `triggers` matches the user message (database driver only)
AI_DATABASE_FALLBACK="لم أجد إجابة مطابقة في قاعدة المعرفة. جرّب كلمات أخرى."
AI_DATABASE_EMPTY="كيف أقدر أساعدك؟"

# --- أمان الإنتاج (مراجعة عند النشر) ---
# - غيّر كلمات المرور الافتراضية لحسابات الـ seed ولا ترفع ملف .env الحقيقي.
# - مسارات API/auth تستخدم throttle في routes/api.php (حدود محاولات التسجيل/الدخول).
# - فعّل APP_DEBUG=false واستخدم HTTPS وCORS صارم في الإنتاج.
